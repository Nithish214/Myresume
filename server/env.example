# Copy this file to ".env" and fill in your real values.
# The server reads these with dotenv - see config/db.js and server.js

# MongoDB connection string.
# Local example:      mongodb://127.0.0.1:27017/resume-website
# Atlas example:       mongodb+srv://<user>:<password>@cluster0.mongodb.net/resume-website
MONGO_URI=mongodb+srv://nithish21kumar04:GoodMorning123@cluster0.dxccfh7.mongodb.net/resume-website?appName=Cluster0

# Port the Express API listens on
PORT=5000

# The origin your React dev server / production site runs on.
# Used to configure CORS so the browser is allowed to call this API.
CLIENT_URL=http://localhost:5173

# Simple shared password used by the mock admin login (see README for why
# this should be replaced with real auth like JWT before going to production)
ADMIN_PASSWORD=changeme123
