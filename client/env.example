# Copy this file to ".env" and adjust if needed.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Base URL of the Express API (see server/server.js)
VITE_API_URL=http://localhost:5000/api

# Password for the mock admin page (client/src/pages/Admin.jsx).
# This is NOT secure - it's a client-side check for learning purposes only.
# See the README for how to replace this with real server-side auth (JWT).
VITE_ADMIN_PASSWORD=changeme123
